Host mpi-gitlab
    HostName gitlab.mpi-sws.org
    User git-rtw
    IdentityFile ~/.ssh/mpi_key
    IdentitiesOnly yes

Host contact-mpi
    HostName contact.mpi-sws.org
    User biteye
    IdentityFile ~/.ssh/mpi_key

Host mpi-proxy
    HostName contact.mpi-sws.org
    User biteye
    DynamicForward 8890
    ExitOnForwardFailure yes 
    IdentityFile ~/.ssh/mpi_key
    RequestTTY no 
    LogLevel QUIET 

Host tock-mpi
    HostName tock.mpi-sws.org
    User biteye
    IdentityFile ~/.ssh/mpi_key
    Port 22
    ProxyJump contact-mpi
