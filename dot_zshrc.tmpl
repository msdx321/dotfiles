# ----------------------------------
# Shell behavior and styles
# ----------------------------------
bindkey -e

zstyle ':fzf-tab:*' fzf-command ftb-tmux-popup
zstyle ':omz:plugins:ssh-agent' agent-forwarding 'yes'
zstyle ':omz:plugins:ssh-agent' quiet 'yes'
zstyle ':zim:zmodule' use 'degit'

# ----------------------------------
# Environment
# ----------------------------------
FZF_TMUX=1
FZF_TMUX_OPTS='-p80%'
ZIM_HOME=~/.zim
ZSH_CACHE_DIR=~/.cache/zim
ZSH_COMPLETION_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/zsh"
ZSH_TMUX_AUTOSTART=true
ZSH_TMUX_DEFAULT_SESSION_NAME="{{ .chezmoi.os }}"
{{- if lookPath "nvim" }}
EDITOR="nvim"
{{- else }}
EDITOR="vim"
{{- end }}
PATH="$HOME/.local/bin:$PATH"

[[ -d $ZSH_COMPLETION_CACHE_DIR ]] || command mkdir -p "$ZSH_COMPLETION_CACHE_DIR"
zstyle ':zim:completion' dumpfile "${ZSH_COMPLETION_CACHE_DIR}/zcompdump"
zstyle ':completion::complete:*' cache-path "${ZSH_COMPLETION_CACHE_DIR}/zcompcache"

# ----------------------------------
# Tool bootstrap
# ----------------------------------
# Install TPM if missing.
if [[ ! -f $HOME/.tmux/plugins/tpm/tpm ]]; then
  print -P "%F{33} %F{220}Installing TPM"
  command mkdir -p "$HOME/.tmux/plugins" && command chmod g-rwX "$HOME/.tmux/plugins"
  command git clone https://github.com/tmux-plugins/tpm "$HOME/.tmux/plugins/tpm" && \
    print -P "%F{33} %F{34}Installation successful.%f%b" || \
    print -P "%F{160} The clone has failed.%f%b"
fi

# Download zimfw if missing.
[[ ! -d $ZSH_CACHE_DIR ]] && command mkdir -p "$ZSH_CACHE_DIR"
if [[ ! -e ${ZIM_HOME}/zimfw.zsh ]]; then
  curl -fsSL --create-dirs -o ${ZIM_HOME}/zimfw.zsh \
      https://github.com/zimfw/zimfw/releases/latest/download/zimfw.zsh
fi

# ----------------------------------
# Plugin manager initialization
# ----------------------------------
# Install missing modules and update ${ZIM_HOME}/init.zsh if missing or outdated.
if [[ ! ${ZIM_HOME}/init.zsh -nt ${ZIM_CONFIG_FILE:-${ZDOTDIR:-${HOME}}/.zimrc} ]]; then
  source ${ZIM_HOME}/zimfw.zsh init -q
fi

# Initialize modules.
source ${ZIM_HOME}/init.zsh

# ----------------------------------
# Command shortcuts and wrappers
# ----------------------------------
if (( $+commands[nvim] )); then
  alias vim="nvim"
fi

if (( $+commands[helix] )); then
  alias hx="helix"
fi

if (( $+commands[lazygit] )); then
  git() {
    if [[ $# -eq 0 ]]; then
      lazygit
    else
      command git "$@"
    fi
  }
fi

{{ if eq .chezmoi.os "darwin" -}}
compress_dir() {
    local dir="${1:-eval-results}"
    find "$dir" -type f -print0 | xargs -0 -n 1 -P 8 sudo afsctool -c
}

{{ end -}}

# ----------------------------------
# Prompt configuration
# ----------------------------------
if (( $+commands[starship] )); then
  STARSHIP_INIT="${XDG_CACHE_HOME:-$HOME/.cache}/starship/init.zsh"
  if [[ ! $STARSHIP_INIT -nt $commands[starship] || ! $STARSHIP_INIT.zwc -nt $STARSHIP_INIT ]]; then
    command mkdir -p "${STARSHIP_INIT:h}"
    starship init zsh >| "$STARSHIP_INIT"
    zcompile "$STARSHIP_INIT"
  fi
  source "$STARSHIP_INIT"
fi
